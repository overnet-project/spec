{
  "description": "A matching authoritative ban exception overrides a matching +b ban for hosted-channel join admission.",
  "input": {
    "operation": "authoritative_join_admission",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "actor_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
    "actor_mask": "bob!u@safe.example",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "ban_masks": [
            "*!*@safe.example"
          ],
          "except_masks": [
            "*!*@safe.example"
          ]
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "admission.0.allowed", "equals": true },
      { "path": "admission.0.reason", "equals": "" }
    ]
  }
}
