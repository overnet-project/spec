{
  "description": "A hosted channel with +l denies new join admission when the present-member count is already at the authoritative limit.",
  "input": {
    "operation": "authoritative_join_admission",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "actor_pubkey": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "user_limit": 1
        },
        {
          "type": "put_user",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 2,
          "target_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "roles": [
            "irc.operator"
          ]
        },
        {
          "type": "join",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 3
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "admission.0.allowed", "equals": false },
      { "path": "admission.0.reason", "equals": "+l" }
    ]
  }
}
