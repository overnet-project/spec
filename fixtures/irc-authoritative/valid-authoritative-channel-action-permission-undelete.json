{
  "description": "A retained operator may undelete a tombstoned hosted channel using the same deterministic binding.",
  "input": {
    "operation": "authoritative_channel_action_permission",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "actor_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    "action": "undelete",
    "authoritative_scenario": {
      "events": [
        {
          "type": "put_user",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "target_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "roles": [
            "irc.operator"
          ]
        },
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 2,
          "topic": "Ops room",
          "tombstoned": true
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "permission.0.allowed", "equals": true },
      { "path": "permission.0.action", "equals": "undelete" },
      { "path": "permission.0.group_metadata.topic", "equals": "Ops room" },
      { "path": "permission.0.group_metadata.tombstoned", "equals": "1" }
    ]
  }
}
