{
  "description": "A restricted closed hosted channel requests moderated admission instead of returning ordinary +i denial for an authenticated user.",
  "input": {
    "operation": "authoritative_join_admission",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "actor_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
    "actor_mask": "bob!u@127.0.0.2",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "closed": true,
          "restricted": true
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "admission.0.allowed", "equals": false },
      { "path": "admission.0.request_join", "equals": true },
      { "path": "admission.0.reason", "equals": "join_request" }
    ]
  }
}
