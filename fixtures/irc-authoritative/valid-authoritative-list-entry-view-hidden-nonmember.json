{
  "description": "A hidden hosted channel is omitted from LIST for non-members.",
  "input": {
    "operation": "authoritative_list_entry_view",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "actor_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "hidden": true,
          "topic": "Hidden ops"
        },
        {
          "type": "put_user",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 2,
          "target_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "roles": [
            "irc.operator"
          ]
        },
        {
          "type": "join",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 3
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "view.0.visible_in_list", "equals": false },
      { "path": "view.0.reason", "equals": "hidden" }
    ]
  }
}
