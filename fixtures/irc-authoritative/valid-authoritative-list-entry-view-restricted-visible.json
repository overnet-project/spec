{
  "description": "A restricted hosted channel remains list-visible unless another visibility flag suppresses it.",
  "input": {
    "operation": "authoritative_list_entry_view",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "actor_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "closed": true,
          "restricted": true,
          "topic": "Restricted ops"
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "view.0.visible_in_list", "equals": true },
      { "path": "view.0.topic", "equals": "Restricted ops" }
    ]
  }
}
