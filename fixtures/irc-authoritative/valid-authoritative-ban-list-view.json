{
  "description": "A hosted channel ban-list view exposes the normalized IRC ban masks derived from authoritative metadata.",
  "input": {
    "operation": "authoritative_ban_list_view",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "ban_masks": [
            "*!*@127.0.0.1",
            "bad!*@*"
          ]
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "view.0.ban_masks.0", "equals": "*!*@127.0.0.1" },
      { "path": "view.0.ban_masks.1", "equals": "bad!*@*" }
    ]
  }
}
