{
  "description": "An unauthenticated actor cannot create a hosted channel on first authoritative JOIN.",
  "input": {
    "operation": "authoritative_join_admission",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#new",
    "authoritative_events": []
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "admission.0.allowed", "equals": false },
      { "path": "admission.0.create_channel", "equals": false },
      { "path": "admission.0.auth_required", "equals": true },
      { "path": "admission.0.reason", "equals": "auth_required" }
    ]
  }
}
