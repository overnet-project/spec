{
  "description": "A restricted closed hosted channel keeps an unmatched join request pending instead of granting membership.",
  "input": {
    "operation": "authoritative_channel_view",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "closed": true,
          "restricted": true,
          "topic": "Restricted ops"
        },
        {
          "type": "join",
          "pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
          "created_at": 2,
          "actor_mask": "bob!u@127.0.0.2"
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "view.0.members", "equals": [] },
      { "path": "view.0.present_members", "equals": [] },
      { "path": "view.0.pending_join_requests.0.pubkey", "equals": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb" },
      { "path": "view.0.pending_join_requests.0.actor_mask", "equals": "bob!u@127.0.0.2" }
    ]
  }
}
