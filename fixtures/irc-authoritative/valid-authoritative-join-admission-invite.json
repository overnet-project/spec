{
  "description": "A matching pending invite authorizes join admission to a closed hosted channel and exposes the invite code.",
  "input": {
    "operation": "authoritative_join_admission",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "actor_pubkey": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "closed": true
        },
        {
          "type": "invite",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 2,
          "code": "invite-bob",
          "target_pubkey": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "admission.0.allowed", "equals": true },
      { "path": "admission.0.member", "equals": false },
      { "path": "admission.0.present", "equals": false },
      { "path": "admission.0.invite_code", "equals": "invite-bob" },
      { "path": "admission.0.reason", "equals": "" }
    ]
  }
}
