{
  "description": "A tombstoned hosted channel is hidden from LIST and reports symbolic deleted visibility state.",
  "input": {
    "operation": "authoritative_list_entry_view",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#graveyard",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "tombstoned": true
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "view.0.visible_in_list", "equals": false },
      { "path": "view.0.reason", "equals": "deleted" }
    ]
  }
}
