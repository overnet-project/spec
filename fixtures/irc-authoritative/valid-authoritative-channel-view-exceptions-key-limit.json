{
  "description": "An authoritative hosted-channel view exposes invite exceptions, ban exceptions, keyed-mode state, and user limit state in addition to the existing moderated-channel flags.",
  "input": {
    "operation": "authoritative_channel_view",
    "session_config": {
      "authority_profile": "nip29",
      "group_host": "groups.example.test"
    },
    "network": "irc.example.test",
    "target": "#ops",
    "authoritative_scenario": {
      "events": [
        {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "closed": true,
          "moderated": true,
          "topic_restricted": true,
          "topic": "Ops room",
          "except_masks": [
            "*!*@safe.example"
          ],
          "invite_exception_masks": [
            "*!*@invited.example"
          ],
          "key": "hunter2",
          "user_limit": 12
        }
      ]
    }
  },
  "expected": {
    "valid": true,
    "assertions": [
      { "path": "view.0.channel_modes", "equals": "+iklmnt" },
      { "path": "view.0.exception_masks.0", "equals": "*!*@safe.example" },
      { "path": "view.0.invite_exception_masks.0", "equals": "*!*@invited.example" },
      { "path": "view.0.channel_key", "equals": "hunter2" },
      { "path": "view.0.user_limit", "equals": 12 }
    ]
  }
}
