{
  "description": "A command error diagnostic record that includes structured error details violates the default runtime diagnostics safety contract.",
  "input": {
    "diagnostic_record": {
      "diagnostic_type": "command.error",
      "surface": "program.services",
      "method": "secrets.get",
      "session_id": "instance-1",
      "program_id": "diagnostic.program",
      "request_id": "req-5",
      "duration_ms": 1,
      "error": {
        "code": "runtime.permission_denied",
        "message": "Permission denied for method secrets.get",
        "details": {
          "secret_name": "<fixture-secret-leaked-detail>"
        }
      }
    }
  },
  "expected": {
    "diagnostic_valid": false,
    "reason": "Default runtime diagnostics MUST NOT contain structured error details.",
    "invariants": [
      {
        "surface": "diagnostics",
        "must_not_contain": [
          "<fixture-secret-leaked-detail>",
          "details"
        ]
      }
    ]
  }
}
