{
  "description": "A command diagnostic record that includes request params violates the default runtime diagnostics safety contract.",
  "input": {
    "diagnostic_record": {
      "diagnostic_type": "command.success",
      "surface": "program.services",
      "method": "config.get",
      "session_id": "instance-1",
      "program_id": "diagnostic.program",
      "request_id": "req-4",
      "duration_ms": 1,
      "params": {
        "private": "<fixture-secret-leaked-param>"
      }
    }
  },
  "expected": {
    "diagnostic_valid": false,
    "reason": "Default runtime diagnostics MUST NOT contain request parameters.",
    "invariants": [
      {
        "surface": "diagnostics",
        "must_not_contain": [
          "<fixture-secret-leaked-param>"
        ]
      }
    ]
  }
}
