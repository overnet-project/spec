{
  "description": "Operators can list pending authoritative join requests for a restricted hosted channel.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "alice",
      "authority_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "joined_channels": [
        "#ops"
      ]
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "closed": true,
              "restricted": true
            },
            {
              "type": "put_user",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 2,
              "target_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "roles": [
                "irc.operator"
              ]
            },
            {
              "type": "join",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 3
            },
            {
              "type": "join",
              "pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
              "created_at": 4,
              "actor_mask": "bob!u@127.0.0.2"
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "OVERNETCHANNEL REQUESTS #ops"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local 338 alice #ops bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb bob!u@127.0.0.2",
      ":overnet.irc.local 339 alice #ops :End of authoritative join request list"
    ]
  }
}
