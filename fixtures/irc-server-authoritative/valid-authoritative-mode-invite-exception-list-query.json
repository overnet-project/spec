{
  "description": "MODE +I with no argument renders the authoritative invite-exception list through 346 and 347 numerics.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "alice",
      "authority_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "joined_channels": [
        "#ops"
      ]
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "invite_exception_masks": [
                "*!*@invited.example"
              ]
            },
            {
              "type": "put_user",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 2,
              "target_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "roles": [
                "irc.operator"
              ]
            },
            {
              "type": "join",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 3
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "MODE #ops +I"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local 346 alice #ops *!*@invited.example overnet.irc.local 0",
      ":overnet.irc.local 347 alice #ops :End of channel invite exception list"
    ]
  }
}
