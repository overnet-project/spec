{
  "description": "A hosted channel MODE +b query renders the authoritative ban list through 367 and 368 numerics.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "alice",
      "authority_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "joined_channels": [
        "#ops"
      ]
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "ban_masks": [
                "*!*@127.0.0.1"
              ]
            },
            {
              "type": "put_user",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 2,
              "target_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "roles": [
                "irc.operator"
              ]
            },
            {
              "type": "join",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 3
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "MODE #ops +b"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local 367 alice #ops *!*@127.0.0.1 overnet.irc.local 0",
      ":overnet.irc.local 368 alice #ops :End of channel ban list"
    ]
  }
}
