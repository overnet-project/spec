{
  "description": "A client with account-notify receives ACCOUNT login updates for users on a shared channel.",
  "input": {
    "server_view": {
      "adapter_config": {
        "authority_profile": "nip29"
      },
      "channel_members": {
        "#ops": [
          "alice",
          "bob"
        ]
      }
    },
    "client": {
      "registered": true,
      "nick": "alice",
      "capabilities": [
        "account-notify"
      ],
      "joined_channels": [
        "#ops"
      ]
    },
    "known_nicks": [
      "bob"
    ],
    "account_update": {
      "nick": "bob",
      "account": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    }
  },
  "expected": {
    "lines": [
      ":bob!bob@127.0.0.1 ACCOUNT bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    ]
  }
}
