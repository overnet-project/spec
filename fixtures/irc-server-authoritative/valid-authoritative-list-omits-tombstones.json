{
  "description": "LIST includes active hosted channels and omits tombstoned hosted channels discovered from authoritative metadata.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "alice"
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "topic": "Ops room"
            },
            {
              "type": "put_user",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 2,
              "target_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "roles": [
                "irc.operator"
              ]
            },
            {
              "type": "join",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 3
            }
          ]
        },
        "discovered": true
      },
      "#graveyard": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "topic": "Dead room",
              "tombstoned": true
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "LIST"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local 321 alice Channel :Users Name",
      ":overnet.irc.local 322 alice #ops 1 :Ops room",
      ":overnet.irc.local 323 alice :End of /LIST"
    ]
  }
}
