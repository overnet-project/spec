{
  "description": "A tombstoned hosted channel rejects JOIN with 403 rather than silently recreating it.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "bob",
      "authority_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    },
    "authoritative_channels": {
      "#graveyard": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "tombstoned": true
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "JOIN #graveyard"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local 403 bob #graveyard :No such channel"
    ]
  }
}
