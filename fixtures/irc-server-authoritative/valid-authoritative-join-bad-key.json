{
  "description": "A hosted channel using authoritative +k rejects JOIN with 475 when the supplied key is missing or incorrect.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "bob",
      "authority_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    },
    "authoritative_channels": {
      "#locked": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "key": "hunter2"
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "JOIN #locked wrong"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local 475 bob #locked :Cannot join channel (+k)"
    ]
  }
}
