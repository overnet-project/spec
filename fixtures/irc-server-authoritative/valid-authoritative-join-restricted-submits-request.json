{
  "description": "A restricted closed hosted channel accepts an authenticated join request without bootstrapping channel membership.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "bob",
      "username": "u",
      "peerhost": "127.0.0.2",
      "authority_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "closed": true,
              "restricted": true,
              "topic": "Restricted ops"
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "JOIN #ops"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local NOTICE bob :Join request submitted for #ops"
    ],
    "joined_channels": []
  }
}
