{
  "description": "A non-operator member receives 482 when changing TOPIC on a topic-restricted hosted channel.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "bob",
      "authority_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      "joined_channels": [
        "#ops"
      ]
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "topic_restricted": true
            },
            {
              "type": "put_user",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 2,
              "target_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
              "roles": []
            },
            {
              "type": "join",
              "pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
              "created_at": 3
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "TOPIC #ops :new topic"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local 482 bob #ops :You're not channel operator"
    ]
  }
}
