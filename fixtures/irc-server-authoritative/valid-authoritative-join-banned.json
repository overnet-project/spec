{
  "description": "A banned authenticated client receives 474 when joining a discovered hosted channel.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test"
      }
    },
    "client": {
      "registered": true,
      "nick": "bob",
      "username": "u",
      "peerhost": "127.0.0.1",
      "authority_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "closed": true,
              "ban_masks": [
                "*!*@127.0.0.1"
              ]
            }
          ]
        },
        "discovered": true
      }
    },
    "line": "JOIN #ops"
  },
  "expected": {
    "lines": [
      ":overnet.irc.local 474 bob #ops :Cannot join channel (+b)"
    ]
  }
}
