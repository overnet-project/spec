{
  "description": "When a secret rotates behind a stable name, the runtime revokes outstanding handles for that name and records a rotation audit event without exposing plaintext.",
  "input": {
    "runtime": {
      "production_oriented": true,
      "now_ms": 1700000200000,
      "secrets": {
        "irc-sasl-password": "<fixture-secret-irc-sasl-password-v1>",
        "other-secret": "<fixture-secret-other>"
      },
      "issued_handles": [
        {
          "id": "sh_fixture_rotated_a",
          "name": "irc-sasl-password",
          "session_id": "instance-1",
          "program_id": "irc.program",
          "purpose": "adapters.open_session:irc.real:sasl_password",
          "expires_at_ms": 1700000300000
        },
        {
          "id": "sh_fixture_rotated_b",
          "name": "other-secret",
          "session_id": "instance-2",
          "program_id": "other.program",
          "purpose": "adapter.connect:secondary",
          "expires_at_ms": 1700000300000
        }
      ]
    },
    "lifecycle": {
      "type": "secret_rotated",
      "name": "irc-sasl-password",
      "new_value": "<fixture-secret-irc-sasl-password-v2>"
    }
  },
  "expected": {
    "effects": {
      "revoked_handle_ids": ["sh_fixture_rotated_a"],
      "remaining_handle_ids": ["sh_fixture_rotated_b"]
    },
    "audit_events": [
      {
        "action": "secret.rotate",
        "outcome": "rotated",
        "name": "irc-sasl-password",
        "revoked": 1
      }
    ],
    "invariants": [
      {
        "surface": "audit",
        "must_not_contain": [
          "<fixture-secret-irc-sasl-password-v1>",
          "<fixture-secret-irc-sasl-password-v2>",
          "<fixture-secret-other>"
        ]
      }
    ]
  }
}
