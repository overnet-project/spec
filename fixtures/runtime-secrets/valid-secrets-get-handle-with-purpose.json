{
  "description": "A production-oriented runtime issues a handle-only secrets.get result bound to the requesting instance and declared purpose.",
  "input": {
    "runtime": {
      "production_oriented": true,
      "now_ms": 1700000000000,
      "session_id": "instance-1",
      "program_id": "secrets.example",
      "permissions": ["secrets.read"],
      "secret_handle_ttl_ms": 300000,
      "secrets": {
        "api-token": "<fixture-secret-api-token>"
      },
      "secret_policies": {
        "api-token": {
          "allowed_program_ids": ["secrets.example"],
          "allowed_purposes": ["adapter.connect:primary"]
        }
      }
    },
    "request": {
      "method": "secrets.get",
      "params": {
        "name": "api-token",
        "purpose": "adapter.connect:primary"
      }
    }
  },
  "expected": {
    "response": {
      "ok": true
    },
    "assertions": [
      {
        "path": "result.name",
        "equals": "api-token"
      },
      {
        "path": "result.secret_handle.id",
        "type": "string",
        "min_length": 1
      },
      {
        "path": "result.secret_handle.expires_at",
        "equals": 1700000300
      },
      {
        "path": "result.value",
        "absent": true
      }
    ],
    "audit_events": [
      {
        "action": "secret_handle.issue",
        "outcome": "issued",
        "name": "api-token",
        "session_id": "instance-1",
        "program_id": "secrets.example",
        "purpose": "adapter.connect:primary"
      }
    ],
    "invariants": [
      {
        "surface": "response",
        "must_not_contain": ["<fixture-secret-api-token>"]
      },
      {
        "surface": "audit",
        "must_not_contain": ["<fixture-secret-api-token>"]
      }
    ]
  }
}
