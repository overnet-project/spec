{
  "description": "An unknown secret name is rejected with the same protocol error class used for denied secret access and without exposing plaintext.",
  "input": {
    "runtime": {
      "production_oriented": true,
      "now_ms": 1700000000000,
      "session_id": "instance-1",
      "program_id": "secrets.example",
      "permissions": ["secrets.read"],
      "secrets": {
        "api-token": "<fixture-secret-api-token>"
      }
    },
    "request": {
      "method": "secrets.get",
      "params": {
        "name": "missing-token"
      }
    }
  },
  "expected": {
    "response": {
      "ok": false,
      "error": {
        "code": "protocol.invalid_params",
        "message": "Secret access denied or unavailable"
      }
    },
    "assertions": [
      {
        "path": "error.details.param",
        "equals": "name"
      }
    ],
    "audit_events": [
      {
        "action": "secret_handle.issue",
        "outcome": "denied",
        "name": "missing-token",
        "session_id": "instance-1",
        "program_id": "secrets.example",
        "reason": "secret_unavailable"
      }
    ],
    "invariants": [
      {
        "surface": "response",
        "must_not_contain": ["<fixture-secret-api-token>"]
      },
      {
        "surface": "audit",
        "must_not_contain": ["<fixture-secret-api-token>"]
      }
    ]
  }
}
