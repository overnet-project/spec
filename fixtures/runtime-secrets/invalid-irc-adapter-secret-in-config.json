{
  "description": "When an adapter companion specification defines a secret-bearing IRC slot, the program MUST supply it through secret_handles rather than plaintext config.",
  "input": {
    "runtime": {
      "production_oriented": true,
      "now_ms": 1700000000000,
      "session_id": "instance-1",
      "program_id": "irc.program",
      "permissions": ["adapters.use"],
      "adapters": [
        {
          "adapter_id": "irc.real",
          "defined_secret_slots": ["server_password", "nickserv_password", "sasl_password"]
        }
      ]
    },
    "request": {
      "method": "adapters.open_session",
      "params": {
        "adapter_id": "irc.real",
        "config": {
          "network": "irc.libera.chat",
          "nick": "overnet-bot",
          "sasl_password": "<fixture-secret-irc-sasl-password>"
        }
      }
    }
  },
  "expected": {
    "response": {
      "ok": false,
      "error": {
        "code": "protocol.invalid_params"
      }
    },
    "assertions": [
      {
        "path": "error.details.param",
        "equals": "config.sasl_password"
      }
    ],
    "invariants": [
      {
        "surface": "response",
        "must_not_contain": ["<fixture-secret-irc-sasl-password>"]
      }
    ]
  }
}
