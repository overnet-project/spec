{
  "description": "adapters.open_session rejects a malformed secret_handle object whose id field is missing.",
  "input": {
    "runtime": {
      "production_oriented": true,
      "now_ms": 1700000000000,
      "session_id": "instance-1",
      "program_id": "irc.program",
      "permissions": ["adapters.use"],
      "adapters": [
        {
          "adapter_id": "irc.real",
          "defined_secret_slots": ["server_password", "nickserv_password", "sasl_password"]
        }
      ]
    },
    "request": {
      "method": "adapters.open_session",
      "params": {
        "adapter_id": "irc.real",
        "secret_handles": {
          "sasl_password": {
            "expires_at": 1700000300
          }
        }
      }
    }
  },
  "expected": {
    "response": {
      "ok": false,
      "error": {
        "code": "protocol.invalid_params"
      }
    },
    "assertions": [
      {
        "path": "error.details.param",
        "equals": "secret_handles.sasl_password.id"
      }
    ]
  }
}
