{
  "description": "A secret name that exists but is unauthorized for the requesting program is rejected with the same error code and redacted message as an unknown secret.",
  "input": {
    "runtime": {
      "production_oriented": true,
      "now_ms": 1700000000000,
      "session_id": "instance-1",
      "program_id": "untrusted.program",
      "permissions": ["secrets.read"],
      "secrets": {
        "server-password": "<fixture-secret-server-password>"
      },
      "secret_policies": {
        "server-password": {
          "allowed_program_ids": ["trusted.program"]
        }
      }
    },
    "request": {
      "method": "secrets.get",
      "params": {
        "name": "server-password"
      }
    }
  },
  "expected": {
    "response": {
      "ok": false,
      "error": {
        "code": "protocol.invalid_params",
        "message": "Secret access denied or unavailable"
      }
    },
    "assertions": [
      {
        "path": "error.details.param",
        "equals": "name"
      }
    ],
    "audit_events": [
      {
        "action": "secret_handle.issue",
        "outcome": "denied",
        "name": "server-password",
        "session_id": "instance-1",
        "program_id": "untrusted.program",
        "reason": "secret_unavailable"
      }
    ],
    "invariants": [
      {
        "surface": "response",
        "must_not_contain": ["server-password", "<fixture-secret-server-password>"]
      },
      {
        "surface": "audit",
        "must_not_contain": ["<fixture-secret-server-password>"]
      }
    ]
  }
}
