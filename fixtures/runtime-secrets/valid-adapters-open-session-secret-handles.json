{
  "description": "A valid adapters.open_session request consumes a secret handle inside the runtime boundary and returns only a non-secret adapter session identifier.",
  "input": {
    "runtime": {
      "production_oriented": true,
      "now_ms": 1700000000000,
      "session_id": "instance-1",
      "program_id": "irc.program",
      "permissions": ["adapters.use"],
      "secrets": {
        "irc-sasl-password": "<fixture-secret-irc-sasl-password>"
      },
      "issued_handles": [
        {
          "id": "sh_fixture_valid_sasl",
          "name": "irc-sasl-password",
          "session_id": "instance-1",
          "program_id": "irc.program",
          "purpose": "adapters.open_session:irc.real:sasl_password",
          "allowed_methods": ["adapters.open_session"],
          "allowed_adapter_ids": ["irc.real"],
          "allowed_secret_slots": ["sasl_password"],
          "expires_at_ms": 1700000300000
        }
      ],
      "adapters": [
        {
          "adapter_id": "irc.real",
          "defined_secret_slots": ["server_password", "nickserv_password", "sasl_password"]
        }
      ]
    },
    "request": {
      "method": "adapters.open_session",
      "derived_purpose": "adapters.open_session:irc.real:sasl_password",
      "params": {
        "adapter_id": "irc.real",
        "config": {
          "network": "irc.libera.chat",
          "nick": "overnet-bot",
          "sasl_username": "overnet-bot"
        },
        "secret_handles": {
          "sasl_password": {
            "id": "sh_fixture_valid_sasl",
            "expires_at": 1700000300
          }
        }
      }
    }
  },
  "expected": {
    "response": {
      "ok": true
    },
    "assertions": [
      {
        "path": "result.adapter_session_id",
        "type": "string",
        "min_length": 1
      }
    ],
    "audit_events": [
      {
        "action": "secret_handle.resolve",
        "outcome": "resolved",
        "name": "irc-sasl-password",
        "session_id": "instance-1",
        "program_id": "irc.program",
        "purpose": "adapters.open_session:irc.real:sasl_password",
        "method": "adapters.open_session",
        "adapter_id": "irc.real",
        "secret_slot": "sasl_password"
      }
    ],
    "invariants": [
      {
        "surface": "response",
        "must_not_contain": ["<fixture-secret-irc-sasl-password>"]
      },
      {
        "surface": "adapter_session_id",
        "must_not_contain": ["<fixture-secret-irc-sasl-password>"]
      },
      {
        "surface": "notifications",
        "must_not_contain": ["<fixture-secret-irc-sasl-password>"]
      },
      {
        "surface": "documents",
        "must_not_contain": ["<fixture-secret-irc-sasl-password>"]
      },
      {
        "surface": "event_store",
        "must_not_contain": ["<fixture-secret-irc-sasl-password>"]
      },
      {
        "surface": "audit",
        "must_not_contain": ["<fixture-secret-irc-sasl-password>"]
      }
    ]
  }
}
