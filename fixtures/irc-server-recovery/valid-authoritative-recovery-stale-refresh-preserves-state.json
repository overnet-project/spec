{
  "description": "A stale empty relay refresh does not erase cached authoritative channel state for a known hosted channel.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test",
        "authority_relay": {
          "url": "wss://relay.example.test"
        }
      }
    },
    "client": {
      "registered": true,
      "nick": "bob",
      "username": "u",
      "authority_pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "closed": true,
              "topic": "Ops room"
            }
          ]
        },
        "discovered": true
      }
    },
    "operations": [
      {
        "type": "refresh_authoritative_discovery_cache",
        "refresh": true
      },
      {
        "type": "refresh_authoritative_channel_cache",
        "channel": "#ops",
        "refresh": true
      },
      {
        "type": "set_authoritative_channel_events",
        "channel": "#ops",
        "scenario": {
          "events": []
        }
      },
      {
        "type": "refresh_authoritative_channel_cache",
        "channel": "#ops",
        "refresh": true
      },
      {
        "type": "derive_authoritative_channel_view",
        "channel": "#ops"
      }
    ]
  },
  "expected": {
    "assertions": [
      {
        "path": "server.authoritative_discovered_channels.#ops.channel_name",
        "equals": "#ops"
      },
      {
        "path": "server.authoritative_channel_cache.#ops.view.topic",
        "equals": "Ops room"
      },
      {
        "path": "server.authoritative_channel_cache.#ops.view.channel_modes",
        "equals": "+in"
      },
      {
        "path": "results.4.topic",
        "equals": "Ops room"
      }
    ]
  }
}
