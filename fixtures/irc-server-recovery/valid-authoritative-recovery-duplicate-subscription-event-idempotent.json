{
  "description": "Duplicate relay subscription events do not duplicate authoritative presence in the channel cache.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test",
        "authority_relay": {
          "url": "wss://relay.example.test"
        }
      }
    },
    "client": {
      "registered": true,
      "nick": "alice",
      "username": "u",
      "authority_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1
            }
          ]
        },
        "discovered": true
      }
    },
    "operations": [
      {
        "type": "refresh_authoritative_discovery_cache",
        "refresh": true
      },
      {
        "type": "refresh_authoritative_channel_cache",
        "channel": "#ops",
        "refresh": true
      },
      {
        "type": "ensure_authoritative_channel_subscription",
        "channel": "#ops"
      },
      {
        "type": "handle_subscription_event",
        "subscription": "channel_control",
        "channel": "#ops",
        "event": {
          "type": "join",
          "pubkey": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "created_at": 2
        }
      },
      {
        "type": "handle_subscription_event",
        "subscription": "channel_control",
        "channel": "#ops",
        "event": {
          "type": "join",
          "pubkey": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "created_at": 2
        }
      },
      {
        "type": "derive_authoritative_channel_view",
        "channel": "#ops"
      }
    ]
  },
  "expected": {
    "assertions": [
      {
        "path": "server.authoritative_channel_cache.#ops.view.present_members.0.pubkey",
        "equals": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      },
      {
        "path": "server.authoritative_channel_cache.#ops.view.present_members.1",
        "missing": true
      },
      {
        "path": "results.5.present_members.1",
        "missing": true
      }
    ]
  }
}
