{
  "description": "Out-of-order discovery subscription replay does not resurrect a tombstoned hosted channel.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test",
        "authority_relay": {
          "url": "wss://relay.example.test"
        }
      }
    },
    "client": {
      "registered": true,
      "nick": "alice"
    },
    "operations": [
      {
        "type": "ensure_authoritative_discovery_subscription"
      },
      {
        "type": "handle_subscription_event",
        "subscription": "discovery",
        "channel": "#graveyard",
        "event": {
          "type": "metadata_edit",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 2,
          "tombstoned": true
        }
      },
      {
        "type": "handle_subscription_event",
        "subscription": "discovery",
        "channel": "#graveyard",
        "event": {
          "type": "metadata",
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "topic": "Dead room"
        }
      }
    ]
  },
  "expected": {
    "assertions": [
      {
        "path": "server.authoritative_discovered_channels.#graveyard",
        "missing": true
      }
    ]
  }
}
