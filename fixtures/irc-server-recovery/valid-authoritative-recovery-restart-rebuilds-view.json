{
  "description": "A restarted IRC server rebuilds authoritative channel view state from relay snapshots without widening or losing state.",
  "input": {
    "server_view": {
      "network": "irc.example.test",
      "server_name": "overnet.irc.local",
      "adapter_config": {
        "authority_profile": "nip29",
        "group_host": "groups.example.test",
        "authority_relay": {
          "url": "wss://relay.example.test"
        }
      }
    },
    "client": {
      "registered": true,
      "nick": "alice",
      "username": "u",
      "authority_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    },
    "authoritative_channels": {
      "#ops": {
        "scenario": {
          "events": [
            {
              "type": "metadata",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 1,
              "topic": "Recovered topic"
            },
            {
              "type": "put_user",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 2,
              "target_pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "roles": [
                "irc.operator"
              ]
            },
            {
              "type": "join",
              "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
              "created_at": 3
            }
          ]
        },
        "discovered": true
      }
    },
    "operations": [
      {
        "type": "refresh_authoritative_discovery_cache",
        "refresh": true
      },
      {
        "type": "refresh_authoritative_channel_cache",
        "channel": "#ops",
        "refresh": true
      },
      {
        "type": "simulate_restart"
      },
      {
        "type": "refresh_authoritative_discovery_cache",
        "refresh": true
      },
      {
        "type": "refresh_authoritative_channel_cache",
        "channel": "#ops",
        "refresh": true
      },
      {
        "type": "derive_authoritative_channel_view",
        "channel": "#ops"
      }
    ]
  },
  "expected": {
    "assertions": [
      {
        "path": "server.authoritative_discovered_channels.#ops.channel_name",
        "equals": "#ops"
      },
      {
        "path": "server.authoritative_channel_cache.#ops.view.topic",
        "equals": "Recovered topic"
      },
      {
        "path": "server.authoritative_channel_cache.#ops.view.members.0.pubkey",
        "equals": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      },
      {
        "path": "results.5.present_members.0.pubkey",
        "equals": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      }
    ]
  }
}
