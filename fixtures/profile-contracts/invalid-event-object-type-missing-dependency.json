            "overnet_v",
            "overnet_et",
            "overnet_ot",
            "overnet_oid",
            "v",
            "t",
            "o",
            "d"
          ],
          "body_schema": {
            "type": "object",
            "required": [
              "mode"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "references": [],
          "state_effect": "creates",
          "authorization": {
            "model": "external-authority",
            "description": "The IRC network is the external authority for observed channel mode changes."
          },
          "privacy": "public",
          "extensions": {}
        }
      },
      "fixtures": {
        "valid": [],
        "invalid": [
          "fixtures/profile-contracts/invalid-event-object-type-missing-dependency.json"
        ]
      },
      "extensions": {}
    }
  },
  "expected": {
    "overnet_valid": false,
    "profile_contract_valid": false,
    "reason": "profile_contract.event_object_type_dependency_missing"
  }
}
