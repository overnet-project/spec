        "irc.events"
      ],
      "object_types": {
        "irc.network": {
          "description": "An IRC network namespace.",
          "id": {
            "scheme": "profile-defined",
            "pattern": null,
            "examples": [
              "irc:irc.libera.chat"
            ]
          },
          "state": {
            "derivation": "event-log",
            "state_event_type": null
          },
          "extensions": {}
        }
      },
      "event_types": {
        "irc.mode": {
          "description": "An observed IRC channel mode change without a declared chat dependency.",
          "kind": 7800,
          "object_type": "chat.channel",
