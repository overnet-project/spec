{
  "description": "profile contract is invalid when an unknown top-level field appears outside extensions",
  "input": {
    "contract": {
      "contract_version": 1,
      "profile": "chat",
      "profile_version": "1.0.0",
      "status": "draft",
      "description": "Invalid extra top-level field.",
      "capabilities": [
        "chat.events"
      ],
      "object_types": {
        "chat.channel": {
          "description": "A chat channel.",
          "id": {
            "scheme": "profile-defined",
            "pattern": null,
            "examples": [
              "channel:general"
            ]
          },
          "state": {
            "derivation": "event-log",
            "state_event_type": null
          },
          "extensions": {}
        }
      },
      "event_types": {
        "chat.message": {
          "description": "A message sent to a chat channel.",
          "kind": 7800,
          "object_type": "chat.channel",
          "required_tags": [
            "overnet_v",
            "overnet_et",
            "overnet_ot",
            "overnet_oid",
            "v",
            "t",
            "o",
            "d"
          ],
          "body_schema": {
            "type": "object"
          },
          "references": [],
          "state_effect": "creates",
          "authorization": {
            "model": "open",
            "description": "Open."
          },
          "privacy": "public",
          "extensions": {}
        }
      },
      "fixtures": {
        "valid": [],
        "invalid": [
          "fixtures/profile-contracts/invalid-top-level-extra-field.json"
        ]
      },
      "extensions": {},
      "unexpected": true
    }
  },
  "expected": {
    "overnet_valid": false,
    "profile_contract_valid": false,
    "reason": "profile_contract.unknown_top_level_field"
  }
}
