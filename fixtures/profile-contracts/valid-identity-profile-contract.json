            "derivation": "latest-per-author",
            "state_event_type": "identity.profile.updated"
          },
          "extensions": {}
        }
      },
      "event_types": {
        "identity.profile.updated": {
          "description": "Current identity profile state.",
          "kind": 37800,
          "object_type": "identity.profile",
          "required_tags": [
            "overnet_v",
            "overnet_et",
            "overnet_ot",
            "overnet_oid",
            "v",
            "t",
            "o",
            "d"
          ],
          "body_schema": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "display_name": {
                "type": "string"
              }
            }
          },
          "references": [],
          "state_effect": "updates",
          "authorization": {
            "model": "author-is-object-owner",
            "description": "The profile owner controls profile state."
          },
          "privacy": "public",
          "extensions": {}
        }
      },
      "fixtures": {
        "valid": [],
        "invalid": []
      },
      "extensions": {}
    }
  },
  "expected": {
    "overnet_valid": true,
    "profile_contract_valid": true
  }
}
