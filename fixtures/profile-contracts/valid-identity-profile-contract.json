{
  "description": "valid profile contract for identity profile objects referenced by other contracts",
  "input": {
    "contract": {
      "contract_version": 1,
      "profile": "identity",
      "profile_version": "1.0.0",
      "status": "draft",
      "description": "Example identity profile contract.",
