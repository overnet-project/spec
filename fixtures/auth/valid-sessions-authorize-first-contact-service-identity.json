{
  "description": "A first-contact request with a stable presented service identity succeeds interactively and reports first_contact pin state.",
  "input": {
    "agent": {
      "identities": [
        {
          "identity_id": "default",
          "private_key": "1111111111111111111111111111111111111111111111111111111111111111",
          "public_identity": {
            "scheme": "nostr.pubkey",
            "value": "4f355bdcb7cc0af728ef3cceb9615d90684bb5b2ca5f859ab0f0b704075871aa"
          }
        }
      ],
      "policies": [],
      "service_pins": {}
    },
    "request": {
      "type": "request",
      "id": "auth-2",
      "method": "sessions.authorize",
      "params": {
        "program_id": "irc.bridge",
        "identity_id": "default",
        "service": {
          "locators": ["wss://relay.example.test/auth"],
          "service_identity": {
            "scheme": "nostr.pubkey",
            "value": "1111111111111111111111111111111111111111111111111111111111111111",
            "display": "relay.example.test authority"
          },
          "display": "relay.example.test authority"
        },
        "scope": "irc://irc.example.test/overnet",
        "action": "session.authenticate",
        "challenge": {
          "type": "opaque",
          "value": "6cf8a952df516a8e691c6138496516abe84ccfefa9678f518bb52f70b1ca966f"
        },
        "artifacts": [
          {
            "type": "nostr.event",
            "params": {
              "kind": 22242,
              "tags": [
                ["relay", "irc://irc.example.test/overnet"],
                ["challenge", "6cf8a952df516a8e691c6138496516abe84ccfefa9678f518bb52f70b1ca966f"]
              ]
            }
          }
        ]
      }
    }
  },
  "expected": {
    "response": {
      "type": "response",
      "id": "auth-2",
      "ok": true
    },
    "assertions": [
      {
        "path": "result.identity_id",
        "equals": "default"
      },
      {
        "path": "result.service_pin_state",
        "equals": "first_contact"
      },
      {
        "path": "result.artifacts.0.type",
        "equals": "nostr.event"
      },
      {
        "path": "result.artifacts.0.value.kind",
        "equals": 22242
      },
      {
        "path": "result.artifacts.0.value.pubkey",
        "equals": "4f355bdcb7cc0af728ef3cceb9615d90684bb5b2ca5f859ab0f0b704075871aa"
      }
    ]
  }
}
