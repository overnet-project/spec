{
  "description": "An inbound direct-message PRIVMSG routes to the directional chat.dm object keyed by the target nick.",
  "input": {
    "server_view": {
      "network": "irc.libera.chat"
    },
    "client": {
      "registered": true,
      "nick": "alice",
      "joined_channels": []
    },
    "line": "PRIVMSG bob :hello in private"
  },
  "expected": {
    "mapped_overnet_et": "chat.dm_message",
    "mapped_overnet_ot": "chat.dm",
    "mapped_overnet_oid": "irc:irc.libera.chat:dm:bob"
  }
}
