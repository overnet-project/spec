  "input": {
    "server_view": {
      "server_name": "overnet.irc.local",
      "current_nicks": [
        "alice"
      ]
    },
    "client": {
      "registered": true,
      "nick": "alice"
    },
    "line": "PRIVMSG bob :hello"
